Description: Scope background-worker checks to the active test cluster
 The upstream TAP scripts count operating-system processes using grep. This
 also counts pg_virtualenv command lines and workers belonging to unrelated
 PostgreSQL clusters. Query pg_stat_activity instead, which verifies the main
 and dynamic workers registered by the current temporary cluster only.
Author: Pigsty Packaging Team <rh@vonng.com>
Forwarded: no
Last-Update: 2026-07-11

--- a/t/01_basic.t
+++ b/t/01_basic.t
@@ -43,7 +43,7 @@ sleep(5);
 sleep(5);
 
 # Verify that the process is running
-$ret = `ps auwx | grep pg_dbms_job | grep -v grep | wc -l`;
+$ret = `psql -X -d regress_dbms_job -Atc "SELECT count(*) FROM pg_stat_activity WHERE backend_type LIKE 'pg_dbms_job%'"`;
 chomp($ret);
 ok( $ret eq "1", "pg_dbms_job background worker is running");
 
--- a/t/02_async.t
+++ b/t/02_async.t
@@ -13,7 +13,7 @@ sleep(4);
 
 # We should have the bgw and the child still running,
 # the current running jobs must not be stopped
-$ret = `ps auwx | grep pg_dbms_job | grep -v grep | wc -l`;
+$ret = `psql -X -d regress_dbms_job -Atc "SELECT count(*) FROM pg_stat_activity WHERE backend_type LIKE 'pg_dbms_job%'"`;
 chomp($ret);
 ok( $ret eq "2", "Background worker pg_dbms_job and subprocess are running: $ret");
 
@@ -33,6 +33,6 @@ ok( $? == 0 && $ret eq "1", "Found $ret async job in the history");
 sleep(1);
 
 # Now all process must be terminated
-$ret = `ps auwx | grep pg_dbms_job | grep -v grep | wc -l`;
+$ret = `psql -X -d regress_dbms_job -Atc "SELECT count(*) FROM pg_stat_activity WHERE backend_type LIKE 'pg_dbms_job%'"`;
 chomp($ret);
 ok( $ret eq "1", "Asynchronous job is stopped");
