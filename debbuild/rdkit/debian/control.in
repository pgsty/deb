Source: rdkit
Section: science
Priority: optional
Maintainer: Ruohang Feng <rh@vonng.com>
Build-Depends: architecture-is-64-bit,
               architecture-is-little-endian,
               bison,
               catch2,
               cmake,
               debhelper-compat (= 13),
               flex,
               libboost-dev,
               libboost-iostreams-dev,
               libboost-program-options-dev,
               libboost-regex-dev,
               libboost-thread-dev,
               libcairo2-dev,
               libeigen3-dev,
               libfreetype-dev,
               libinchi-dev (>= 1.07.1+dfsg-2),
               libsqlite3-dev,
               postgresql-server-dev-all,
               rapidjson-dev,
               zlib1g-dev
Standards-Version: 4.7.2
Rules-Requires-Root: no
Homepage: https://github.com/rdkit/rdkit

Package: librdkit1t64
Provides: ${t64:Provides}
Replaces: librdkit1
Breaks: librdkit1 (<< ${source:Version}), coot (<< 1.1.15+dfsg-1)
Section: libs
Architecture: any
Depends: ${misc:Depends}, ${shlibs:Depends}
Description: RDKit runtime libraries and data files
 RDKit is a cheminformatics and machine-learning toolkit.
 .
 This package ships the runtime shared libraries and data files required by
 the PostgreSQL cartridge build used by Pigsty.

Package: postgresql-PGVERSION-rdkit
Section: database
Architecture: any
Depends: ${misc:Depends}, ${shlibs:Depends}, postgresql-PGVERSION, librdkit1t64 (= ${binary:Version})
Description: RDKit cartridge for PostgreSQL PGVERSION
 RDKit adds cheminformatics data types, operators, and functions to
 PostgreSQL.
 .
 This package contains the PostgreSQL PGVERSION cartridge built for Pigsty.
