Source: rdkit
Section: science
Priority: optional
Maintainer: Ruohang Feng <rh@vonng.com>
Build-Depends: architecture-is-64-bit,
               architecture-is-little-endian,
               bison,
               catch2,
               cmake,
               debhelper-compat (= 13),
               flex,
               libboost-dev,
               libboost-iostreams-dev,
               libboost-program-options-dev,
               libboost-regex-dev,
               libboost-thread-dev,
               libcairo2-dev,
               libeigen3-dev,
               libfreetype-dev,
               libinchi-dev (>= 1.07.1+dfsg-2),
               librdkit-dev (>= 202503.6),
               librdkit-dev (<< 202503.7~),
               libsqlite3-dev,
               postgresql-server-dev-all,
               rapidjson-dev,
               zlib1g-dev
Standards-Version: 4.7.2
Rules-Requires-Root: no
Homepage: https://github.com/rdkit/rdkit

Package: postgresql-PGVERSION-rdkit
Section: database
Architecture: any
Depends: ${misc:Depends},
         ${shlibs:Depends},
         postgresql-PGVERSION
Description: RDKit cartridge for PostgreSQL PGVERSION
 RDKit adds cheminformatics data types, operators, and functions to
 PostgreSQL.
 .
 This Pigsty package fills PostgreSQL 14-17 gaps on Ubuntu 26.04 while using
 the RDKit runtime supplied by Ubuntu.
