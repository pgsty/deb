#!/usr/bin/make -f

export CC = gcc
export USE_PGXS = 1
export with_llvm = no

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_clean:

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_install:
	+pg_buildext -m "USE_PGXS=1 with_llvm=no" loop postgresql-%v-pg-stat-backtrace

override_dh_installdocs:
	dh_installdocs --all README.md CHANGELOG.md SECURITY.md

%:
	dh $@
