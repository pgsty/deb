#!/usr/bin/make -f

export CC = gcc

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_clean:

override_dh_auto_install:
	+pg_buildext loop postgresql-%v-odbc-fdw
	rm -rf debian/postgresql-*-odbc-fdw/usr/share/doc/postgresql-doc-*/

override_dh_installdocs:
	dh_installdocs --all README.md NEWS.md CONTRIBUTING.md

%:
	dh $@
