+++ b/Makefile	2026-06-19 21:25:14.881327052 +0800
@@ -16,11 +16,14 @@
                                 $(LIBJSON)/json_object_iterator.o $(LIBJSON)/printbuf.o $(LIBJSON)/linkhash.o \
