#!/usr/bin/make -f

export CC = gcc
VERSIONS := $(shell sed -e 's/#.*//' -e '/^[[:space:]]*$$/d' debian/pgversions)
LIBBSON_CFLAGS := $(strip $(shell pkg-config --cflags libbson-1.0))
LIBBSON_LIBS := $(strip $(shell pkg-config --libs libbson-1.0))

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_clean:

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_install:
	set -e; \
	for v in $(VERSIONS); do \
		pkg=postgresql-$$v-pgbson; \
		$(MAKE) PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config USE_PGXS=1 \
			PG_CPPFLAGS="$(LIBBSON_CFLAGS)" \
			BSON_INCLUDES="$(LIBBSON_CFLAGS)" \
			BSON_SHLIB="$(LIBBSON_LIBS)"; \
		$(MAKE) install DESTDIR="$(CURDIR)/debian/$$pkg" \
			PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config USE_PGXS=1 \
			PG_CPPFLAGS="$(LIBBSON_CFLAGS)" \
			BSON_INCLUDES="$(LIBBSON_CFLAGS)" \
			BSON_SHLIB="$(LIBBSON_LIBS)"; \
		echo "postgresql:Depends=postgresql-$$v" >> debian/$$pkg.substvars; \
		echo "postgresql:Breaks=" >> debian/$$pkg.substvars; \
		$(MAKE) clean PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config USE_PGXS=1 \
			PG_CPPFLAGS="$(LIBBSON_CFLAGS)" \
			BSON_INCLUDES="$(LIBBSON_CFLAGS)" \
			BSON_SHLIB="$(LIBBSON_LIBS)"; \
	done

override_dh_installdocs:
	dh_installdocs --all README.* LICENSE

%:
	dh $@
