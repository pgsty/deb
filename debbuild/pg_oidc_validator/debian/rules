#!/usr/bin/make -f

PG_VERSIONS := $(shell tr '\n' ' ' < debian/pgversions)

%:
	dh $@

override_dh_auto_test:

override_dh_auto_build:
	# Built by the outer Makefile with the PostgreSQL 18 C++23 toolchain.

override_dh_auto_clean:
	# Keep the pre-built validator module for packaging.

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_install:
	for PG_VERSION in $(PG_VERSIONS); do \
		FULL_NAME=postgresql-$$PG_VERSION-pg-oidc-validator; \
		dh_installdirs -p$$FULL_NAME; \
		install -D -m 0755 pg_oidc_validator.so \
			$(CURDIR)/debian/$$FULL_NAME/usr/lib/postgresql/$$PG_VERSION/lib/pg_oidc_validator.so; \
	done
