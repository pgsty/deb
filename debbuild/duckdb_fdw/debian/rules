#!/usr/bin/make -f

# Makefile only uses -Wno-maybe-uninitialized (needed on Ubuntu ppc64el) if CC=gcc
export CC = gcc
export PG_CPPFLAGS += -I$(CURDIR)/duckdb-headers
PG_DUCKDB_LIB_DIRS = \
	/usr/lib/postgresql/18/lib \
	/usr/lib/postgresql/17/lib \
	/usr/lib/postgresql/16/lib \
	/usr/lib/postgresql/15/lib \
	/usr/lib/postgresql/14/lib
PG_DUCKDB_LIBS = $(addsuffix /libduckdb.so,$(PG_DUCKDB_LIB_DIRS))

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_configure:
	test -f duckdb-headers/duckdb.h
	test -f duckdb-headers/duckdb.hpp
	for lib in $(PG_DUCKDB_LIBS); do \
		if [ -f "$$lib" ]; then \
			ln -sfn "$$lib" libduckdb.so; \
			exit 0; \
		fi; \
	done; \
	echo "missing libduckdb.so from pg_duckdb" >&2; \
	exit 1

override_dh_auto_build:

override_dh_auto_test:

override_dh_auto_clean:
	# Disable the clean step to avoid cleaning up pre-built binaries

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params="$(foreach dir,$(PG_DUCKDB_LIB_DIRS),-l$(dir) )"

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_install:
	+pg_buildext loop postgresql-%v-duckdb-fdw

override_dh_installdocs:
	dh_installdocs --all README.*

%:
	dh $@
