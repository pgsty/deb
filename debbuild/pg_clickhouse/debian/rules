#!/usr/bin/make -f

export CC = gcc
export CXX = g++
export DEB_BUILD_OPTIONS = parallel=1
export CMAKE_BUILD_PARALLEL_LEVEL = 1

VERSIONS := $(shell cat debian/pgversions)

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_build:
	# Skip git submodule command since vendor/clickhouse-cpp is already included in tarball
	sed -i 's/git submodule update --init/@echo "Skipping submodule (included in tarball)"/' Makefile
	# libcurl before 7.87.0 does not define CURL_WRITEFUNC_ERROR.
	# Backfill the newer sentinel value for older releases.
	for f in src/http.c src/http_streaming.c; do \
		grep -q '^#ifndef CURL_WRITEFUNC_ERROR$$' "$$f" || \
		perl -0pi -e 's{(#include <internal\.h>|#include "internal\.h")}{$$1\n#ifndef CURL_WRITEFUNC_ERROR\n#define CURL_WRITEFUNC_ERROR 0xFFFFFFFF\n#endif}' "$$f"; \
	done

override_dh_auto_test:

override_dh_auto_clean:

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_install:
	set -e; \
	for v in $(VERSIONS); do \
		pkg=postgresql-$$v-clickhouse; \
		$(MAKE) clean; \
		$(MAKE) USE_PGXS=1 PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config; \
		$(MAKE) USE_PGXS=1 PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config DESTDIR=$(CURDIR)/debian/$$pkg install; \
		printf 'postgresql:Depends=postgresql-%s\n' "$$v" >> debian/$$pkg.substvars; \
		printf 'postgresql:Breaks=\n' >> debian/$$pkg.substvars; \
	done

override_dh_installdocs:
	dh_installdocs --all README.*

%:
	dh $@
