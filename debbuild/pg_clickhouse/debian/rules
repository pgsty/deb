#!/usr/bin/make -f

export CC = gcc
export CXX = g++
export DEB_BUILD_OPTIONS = parallel=1
export CMAKE_BUILD_PARALLEL_LEVEL = 1

VERSIONS := $(shell cat debian/pgversions)
LLVM_BINPATH ?= $(shell p="$$(command -v llvm-config-21 || command -v llvm-config-20 || command -v llvm-config-19 || command -v llvm-config-18 || command -v llvm-config-17 || command -v llvm-config-16 || command -v llvm-config-15 || command -v llvm-config-14 || command -v llvm-config 2>/dev/null)"; test -n "$$p" && "$$p" --bindir)

include /usr/share/postgresql-common/pgxs_debian_control.mk

override_dh_auto_build:
	# Skip git submodule command since vendor/clickhouse-cpp is already included in tarball
	sed -i 's/git submodule update --init/@echo "Skipping submodule (included in tarball)"/' Makefile

override_dh_auto_test:

override_dh_auto_clean:

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_install:
	set -e; \
	for v in $(VERSIONS); do \
		pkg=postgresql-$$v-clickhouse; \
		$(MAKE) clean; \
		$(MAKE) USE_PGXS=1 PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config LLVM_BINPATH=$(LLVM_BINPATH); \
		$(MAKE) USE_PGXS=1 PG_CONFIG=/usr/lib/postgresql/$$v/bin/pg_config LLVM_BINPATH=$(LLVM_BINPATH) DESTDIR=$(CURDIR)/debian/$$pkg install; \
		printf 'postgresql:Depends=postgresql-%s\n' "$$v" >> debian/$$pkg.substvars; \
		printf 'postgresql:Breaks=\n' >> debian/$$pkg.substvars; \
	done
	rm -rf debian/postgresql-*-clickhouse/usr/share/doc/postgresql-doc-*/

override_dh_installdocs:
	dh_installdocs --all README.* doc/*.md

%:
	dh $@
