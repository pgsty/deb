#!/usr/bin/make -f

export DH_VERBOSE=1
export DEB_HOST_MULTIARCH := $(shell dpkg-architecture -qDEB_HOST_MULTIARCH)

# Filter out -ffast-math to avoid precision regressions.
export CFLAGS=$(shell dpkg-buildflags --get CFLAGS | sed 's/-ffast-math//g')
export LDFLAGS=$(shell dpkg-buildflags --get LDFLAGS) -Wl,--as-needed

%:
	dh $@ --without autoreconf

override_dh_auto_clean:

override_dh_auto_configure:
	./configure \
		--prefix=/usr/pgedge-17 \
		--bindir=/usr/pgedge-17/bin \
		--libdir=/usr/pgedge-17/lib \
		--includedir=/usr/pgedge-17/include \
		--mandir=/usr/pgedge-17/share/man \
		--datadir=/usr/pgedge-17/share \
		--docdir=/usr/share/doc/pgedge-17 \
		--htmldir=/usr/share/doc/pgedge-17/html \
		--with-system-tzdata=/usr/share/zoneinfo \
		--with-lz4 --with-zstd \
		--with-uuid=e2fs --with-libxml --with-libxslt \
		--with-icu \
		--with-gssapi \
		--with-openssl --with-pam --with-ldap \
		--with-perl --with-python --with-tcl \
		--with-selinux --with-systemd \
		--enable-nls \
		--enable-thread-safety \
		--enable-dtrace \
		--with-extra-version="-pgedge"

override_dh_auto_build:
	cd src/backend && MAKELEVEL=0 $(MAKE) submake-generated-headers
	cd ../..
	MAKELEVEL=0 $(MAKE) -j$(shell nproc) world

override_dh_auto_install:
	$(MAKE) DESTDIR=$(CURDIR)/debian/tmp install-world

override_dh_shlibdeps:
	dh_shlibdeps -l/usr/pgedge-17/lib

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_auto_test:
	:

override_dh_installinit:
	:

override_dh_installsystemd:
	:
