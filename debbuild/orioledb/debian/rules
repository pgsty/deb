#!/usr/bin/make -f

export DH_VERBOSE=1
PG_MAJOR ?= 18
PGBASEINSTDIR := /usr/oriole-$(PG_MAJOR)
DEB_PACKAGE := orioledb-$(PG_MAJOR)
ORIOLEDB_PATCHSET_VERSION ?= 1
ORIOLEDB_VERSION ?= 1.8
ORIOLEDB_BETA ?= beta16

# Filter out -ffast-math which is known to cause precision issues
export CFLAGS=$(shell dpkg-buildflags --get CFLAGS | sed 's/-ffast-math//g')
export LDFLAGS=$(shell dpkg-buildflags --get LDFLAGS) -Wl,--as-needed

%:
	dh $@ --without autoreconf

override_dh_auto_clean:

override_dh_auto_configure:
	./configure \
		--enable-rpath \
		--prefix=$(PGBASEINSTDIR) \
		--includedir=$(PGBASEINSTDIR)/include \
		--mandir=$(PGBASEINSTDIR)/share/man \
		--datadir=$(PGBASEINSTDIR)/share \
		--libdir=$(PGBASEINSTDIR)/lib \
		--docdir=$(PGBASEINSTDIR)/doc \
		--htmldir=$(PGBASEINSTDIR)/doc/html \
		--with-system-tzdata=/usr/share/zoneinfo \
		--with-extra-version=" (OrioleDB $(ORIOLEDB_VERSION)-$(ORIOLEDB_BETA))" \
			--with-lz4 --with-zstd \
			--with-uuid=e2fs --with-libxml --with-libxslt \
			--with-icu --without-llvm \
			--with-python --with-tcl \
			--with-openssl --with-pam --with-ldap \
			--with-selinux --with-systemd \
			--with-includes=/usr/include \
			--enable-nls --enable-dtrace

override_dh_auto_build:
	# Source tarball lacks .git metadata; pin patchset version for contrib/orioledb.
	sed -E -i 's|^ORIOLEDB_PATCHSET_VERSION =.*|ORIOLEDB_PATCHSET_VERSION = $(ORIOLEDB_PATCHSET_VERSION)|' src/Makefile.global
	cd src/backend && MAKELEVEL=0 $(MAKE) submake-generated-headers
	MAKELEVEL=0 $(MAKE) -j$(shell nproc) world-bin

override_dh_auto_install:
	$(MAKE) DESTDIR=$(CURDIR)/debian/$(DEB_PACKAGE) install-world-bin
	for library in $(CURDIR)/debian/$(DEB_PACKAGE)$(PGBASEINSTDIR)/lib/postgresql/*plpython3*.so; do \
		[ -e "$$library" ] && chrpath -d "$$library" || :; \
	done

override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/debian/$(DEB_PACKAGE)$(PGBASEINSTDIR)/lib

override_dh_auto_test:
	:

override_dh_strip:
	dh_strip --no-automatic-dbgsym

override_dh_dwz:
	:

override_dh_makeshlibs:
	:

override_dh_installinit:
	:

override_dh_installsystemd:
	:
